# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=transfer
POSTGRES_USER=transfer
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Prisma için tam URL
DATABASE_URL=postgresql://transfer:CHANGE_ME_strong_password@postgres:5432/transfer

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT (min 64 karakter güvenli random string) ─────────────────────────────
# Üretmek için: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_at_least_64_chars_random_string_hex
JWT_REFRESH_SECRET=CHANGE_ME_different_64_chars_random_string_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Müşteri sitesi origin (SSL varsa https://)
CORS_ORIGIN=http://transfer.example.com

# ─── Şifreleme (API key'leri için) ────────────────────────────────────────────
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_64_char_hex_string_exactly_64_chars_long_random_value

# ─── Para birimi ─────────────────────────────────────────────────────────────
BASE_CURRENCY=TRY

# ─── Sentry (opsiyonel) ───────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── NOT ──────────────────────────────────────────────────────────────────────
# PayTR, AeroDataBox, Netgsm, WhatsApp, SMTP, Döviz API anahtarları
# .env'de OLMAZ — admin panelinden girilir, veritabanında AES-256-GCM ile şifrelenir.
