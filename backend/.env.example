NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transfer_db?schema=public"
REDIS_URL="redis://localhost:6379"

# Güçlü, rastgele değerler girin — openssl rand -hex 32
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

CORS_ORIGIN="http://localhost:5173"

# AES-256-GCM master key — openssl rand -hex 32
# 3. parti API anahtarları (PayTR, uçuş, harita, SMS vb.) admin panelinden bu key ile şifreli saklanır
SETTINGS_ENCRYPTION_KEY=""

BASE_CURRENCY="TRY"
SENTRY_DSN=""
